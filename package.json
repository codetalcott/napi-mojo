{
  "name": "napi-mojo",
  "version": "0.1.0",
  "description": "Build Node.js native addons in Mojo — the Mojo equivalent of napi-rs",
  "main": "index.js",
  "types": "build/index.d.ts",
  "files": [
    "index.js",
    "build/index.d.ts",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetalcott/mojo-node-api.git"
  },
  "bugs": {
    "url": "https://github.com/codetalcott/mojo-node-api/issues"
  },
  "homepage": "https://github.com/codetalcott/mojo-node-api#readme",
  "scripts": {
    "build": "bash build.sh && npm run generate:dts",
    "generate:dts": "node scripts/generate-dts.js",
    "generate:addon": "node scripts/generate-addon.mjs",
    "test": "jest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Wm Talcott <wtalcott@gmail.com>",
  "keywords": [
    "napi",
    "mojo",
    "native-addon",
    "ffi",
    "n-api",
    "node-addon"
  ],
  "optionalDependencies": {
    "@napi-mojo/darwin-arm64": "0.1.0",
    "@napi-mojo/linux-x64": "0.1.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  }
}
